{
  "manifest_version": 3,
  "name": "WatchHistory for YouTube™",
  "short_name": "WatchHistory",
  "version": "1.2.2",
  "description": "Best for when YouTube watch history is off. Tracks up to 1000 videos locally and lets you resume where you left off.",
  "homepage_url": "https://github.com/GeorgeElliott/yt-watch-history",
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png"
    }
  },
  "options_page": "src/options.html",
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "watch-history-for-youtube",
      "strict_min_version": "109.0"
    }
  }
}
